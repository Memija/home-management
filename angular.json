{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "home-management": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              {
                "glob": "worker.min.js",
                "input": "node_modules/tesseract.js/dist",
                "output": "/assets/tesseract"
              },
              {
                "glob": "**/*",
                "input": "node_modules/tesseract.js-core",
                "output": "/assets/tesseract/core"
              }
            ],
            "styles": [
              "src/styles.scss"
            ],
            "server": "src/main.server.ts",
            "outputMode": "server",
            "ssr": {
              "entry": "src/server.ts"
            },
            "stylePreprocessorOptions": {
              "includePaths": [
                "src/styles"
              ]
            },
            "allowedCommonJsDependencies": [
              "jspdf",
              "jspdf-autotable",
              "html2canvas",
              "canvg",
              "dompurify",
              "fflate",
              "rgbcolor",
              "raf",
              "core-js",
              "hammerjs",
              "@grpc/grpc-js",
              "@grpc/proto-loader",
              "tesseract.js",
              "regenerator-runtime",
              "regenerator-runtime/runtime",
              "is-url",
              "whatwg-url"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "headers": {
              // --- Content-Security-Policy Breakdown ---
              //
              // [default-src] The ultimate fallback/catch-all for any resource type not explicitly defined below (like media or manifests).
              // It prevents the browser from defaulting to "allow everything" if a specific directive is missing:
              // - 'self' : Allow fallback resources from the app itself
              // - https://ko-fi.com : Allow fallback resources for the Ko-fi donation widget
              // - https://challenges.cloudflare.com : Allow fallback resources for Cloudflare Turnstile
              //
              // [script-src] Allowed sources for JavaScript execution:
              // - 'self' : App's own JavaScript bundles
              // - 'unsafe-inline' : Required by Angular for inline component styles/scripts
              // - 'unsafe-eval' : Required by Webpack/Angular dev tools and some 3rd-party libs
              // - https://apis.google.com : Firebase Auth & Google Sign-In scripts
              // - https://accounts.google.com : Google Sign-In authentication flows
              // - https://www.gstatic.com : Firebase SDKs and Google widgets
              // - https://storage.ko-fi.com : Ko-fi widget dynamic scripts
              // - https://ko-fi.com : Ko-fi widget core scripts
              // - https://challenges.cloudflare.com : Cloudflare Turnstile CAPTCHA scripts
              //
              // [frame-src] Allowed sources for embedded iframes:
              // - 'self' : App's own iframes
              // - https://*.firebaseapp.com : Firebase Auth hidden iframes (e.g. __auth/iframe)
              // - https://accounts.google.com : Google Sign-In popup iframes
              // - https://ko-fi.com : Ko-fi donation embed iframe
              // - https://challenges.cloudflare.com : Cloudflare Turnstile challenge iframe
              //
              // [connect-src] Allowed URLs for API calls (Fetch, XHR, WebSockets):
              // - 'self' : App's own API endpoints
              // - https://*.firebaseio.com : Firebase Realtime Database (WebSockets/Polling)
              // - https://*.googleapis.com : Firebase Firestore and Auth APIs
              // - https://apis.google.com : Google API endpoints
              // - https://accounts.google.com : Google Auth token endpoints
              // - https://*.firebaseapp.com : Firebase Hosting/Auth endpoints
              // - https://ko-fi.com : Ko-fi widget API requests
              // - https://challenges.cloudflare.com : Cloudflare Turnstile verification endpoints
              //
              // [style-src] Allowed sources for CSS stylesheets:
              // - 'self' : App's own global stylesheets
              // - 'unsafe-inline' : Required for Angular's dynamic component styles
              //
              // [font-src] Allowed sources for web fonts:
              // - 'self' : App's own local fonts
              //
              // [img-src] Allowed sources for images:
              // - 'self' : App's own local images
              // - data: : Base64 encoded inline images
              // - blob: : Locally generated image blobs (e.g., Meter Reader camera previews)
              // - https://*.googleapis.com : Google Maps or Avatar images
              // - https://*.googleusercontent.com : User profile pictures from Google Auth
              // - https://storage.ko-fi.com : Ko-fi widget UI images
              // - https://ko-fi.com : Ko-fi widget UI images
              // - https://*.cloudflare.com : Cloudflare Turnstile assets
              //
              // [worker-src] Allowed sources for Web Workers:
              // - 'self' : App's own local workers (e.g., Tesseract.js local files)
              // - blob: : Required by Tesseract.js to spawn background workers from memory
              "Content-Security-Policy": "default-src 'self' https://ko-fi.com https://challenges.cloudflare.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://apis.google.com https://accounts.google.com https://www.gstatic.com https://storage.ko-fi.com https://ko-fi.com https://challenges.cloudflare.com; frame-src 'self' https://*.firebaseapp.com https://accounts.google.com https://ko-fi.com https://challenges.cloudflare.com; connect-src 'self' https://*.firebaseio.com https://*.googleapis.com https://apis.google.com https://accounts.google.com https://*.firebaseapp.com https://ko-fi.com https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https://*.googleapis.com https://*.googleusercontent.com https://storage.ko-fi.com https://ko-fi.com https://*.cloudflare.com blob:; worker-src 'self' blob:;"
            }
          },
          "configurations": {
            "production": {
              "buildTarget": "home-management:build:production"
            },
            "development": {
              "buildTarget": "home-management:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}
