{
  "name": "home-management",
  "version": "1.1.0",
  "scripts": {
    "ng": "ng",
    "config:generate": "node scripts/generate-firebase-config.js",
    "prestart": "npm run config:generate",
    "start": "ng serve home-management",
    "prebuild": "npm run config:generate",
    "build": "ng build home-management && copy dist\\home-management\\browser\\index.csr.html dist\\home-management\\browser\\index.html",
    "watch": "ng build home-management --watch --configuration development",
    "test": "ng test home-management",
    "pretest:coverage": "npm run config:generate",
    "test:coverage": "ng test home-management --coverage --coverage-reporters=lcovonly --coverage-reporters=text-summary --watch=false",
    "sonar": "sonar-scanner",
    "serve:ssr:home-management": "node dist/home-management/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/animations": "21.2.18",
    "@angular/common": "21.2.18",
    "@angular/compiler": "21.2.18",
    "@angular/core": "21.2.18",
    "@angular/fire": "^21.0.0-rc.0",
    "@angular/forms": "21.2.18",
    "@angular/platform-browser": "21.2.18",
    "@angular/platform-browser-dynamic": "21.2.18",
    "@angular/platform-server": "21.2.18",
    "@angular/router": "21.2.18",
    "@angular/ssr": "21.2.18",
    "chart.js": "^4.5.1",
    "chartjs-plugin-zoom": "^2.2.0",
    "express": "^5.1.0",
    "firebase": "^12.9.0",
    "hammerjs": "^2.0.8",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-angular": "^0.555.0",
    "ng2-charts": "^8.0.0",
    "rxjs": "~7.8.0",
    "tesseract.js": "^7.0.0",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.18",
    "@angular/build": "21.2.18",
    "@angular/cli": "21.2.18",
    "@angular/compiler-cli": "21.2.18",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@vitest/coverage-v8": "^4.1.10",
    "baseline-browser-mapping": "^2.9.17",
    "jsdom": "^27.1.0",
    "sonarqube-scanner": "^4.3.8",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "vitest-sonar-reporter": "^3.0.0",
    "zone.js": "^0.16.0"
  }
}
